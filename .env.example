# ─────────────────────────────────────────────────────────────────
#  .env.example
#
#  Copy this to .env and fill in real values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_DB=odoo
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo

# Odoo host ports (change if something else is already on 8069)
ODOO_PORT=8069
ODOO_LONGPOLL_PORT=8072
