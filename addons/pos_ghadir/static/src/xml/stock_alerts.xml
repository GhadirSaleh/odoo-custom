<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_ghadir.StockBadge" t-inherit="point_of_sale.ProductCard" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('product-content')]" position="inside">
            <span t-if="stockLevel"
                  class="product-stock-badge position-absolute top-0 start-0 m-1"
                  t-att-class="'stock-' + stockLevel">
            </span>
        </xpath>
    </t>
</templates>
