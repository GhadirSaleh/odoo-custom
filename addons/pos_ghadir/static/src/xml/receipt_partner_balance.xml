<?xml version="1.0" encoding="UTF-8"?>
<!--
    Receipt Partner Balance Templates
    =================================
    Three template extensions:
    1. ReceiptHeaderDateTicket — Replaces the default ticket/date header layout
       with a flex row showing ticket number (with optional "VAT" prefix) on the
       left and order date on the right.

    2. ReceiptHeaderBalance — Shows "حساب سابق" (Previous Balance) below the
       customer info on the receipt. Only visible when partnerBalance is defined,
       not NaN, and non-zero.

    3. OrderReceiptBalance — Shows "باقي الحساب" (Remaining Balance) after the
       before-footer section. Only visible when convertedPartnerDue is defined,
       not null, and non-zero.

    Both balance rows use RTL direction for the Arabic labels and LTR for the
    amounts (see pos_custom.scss: .pos-receipt-balance-label / .pos-receipt-balance-amount).

    The currency symbol is read from company.currency_id.symbol at render time.
-->
<templates id="template" xml:space="preserve">
    <!-- Replace default ticket/date header with custom flex layout -->
    <t t-name="pos_ghadir.ReceiptHeaderDateTicket" t-inherit="point_of_sale.ReceiptHeader" t-inherit-mode="extension">
        <xpath expr="//div[contains(@class, 'text-center') and contains(@class, 'pt-3')]" position="replace">
            <div class="pos-receipt-header-row pt-3">
                <span class="pos-receipt-ticket-side">
                    <span class="ticket-name-prefix">
                        <t t-if="order.config._IS_VAT"> VAT </t>
                        Ticket
                    </span>
                    <t t-out="order.pos_reference"/>
                </span>
                <span t-if="order.date_order" id="order-date" class="pos-receipt-date-side" t-out="order.formatDateOrTime('date_order')"/>
            </div>
        </xpath>
    </t>

    <!-- Previous Balance (حساب سابق) — shown below customer info -->
    <t t-name="pos_ghadir.ReceiptHeaderBalance" t-inherit="point_of_sale.ReceiptHeader" t-inherit-mode="extension">
        <xpath expr="//div[@class='pos-receipt-customer mt-2']" position="after">
            <!-- Hidden when balance is undefined, null, NaN, or zero -->
            <div t-if="order.partnerBalance !== undefined and order.partnerBalance !== null and order.partnerBalance == order.partnerBalance and order.partnerBalance != 0" class="pos-receipt-customer-balance mt-2 pos-receipt-balance-row pos-receipt-balance-start">
                <span class="pos-receipt-balance-label">حساب سابق</span>
                <span class="pos-receipt-balance-amount">
                    <t t-esc="order.company?.currency_id?.symbol or '$'"/>
                    <t t-if="order.partnerBalance &lt; 0">-</t>
                    <t t-esc="Math.abs(order.partnerBalance)"/>
                </span>
            </div>
        </xpath>
    </t>

    <!-- Remaining Balance (باقي الحساب) — shown after order items -->
    <t t-name="pos_ghadir.OrderReceiptBalance" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//div[@class='before-footer']" position="after">
            <!-- Hidden when convertedPartnerDue is undefined, null, or zero -->
            <div t-if="order.convertedPartnerDue !== undefined and order.convertedPartnerDue !== null and order.convertedPartnerDue != 0" class="pos-receipt-customer-balance mt-2 text-center pos-receipt-balance-row">
                <span class="pos-receipt-balance-label">باقي الحساب</span>
                <span class="pos-receipt-balance-amount">
                    <t t-esc="order.company?.currency_id?.symbol or '$'"/>
                    <t t-if="order.convertedPartnerDue &lt; 0">-</t>
                    <t t-esc="Math.abs(order.convertedPartnerDue)"/>
                </span>
            </div>
        </xpath>
    </t>
</templates>
